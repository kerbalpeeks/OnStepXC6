// -------------------------------------------------------------------------------------------------
// Secrets.h.example — template for WiFi credentials
//
// 1. Copy this file to Secrets.h  (same directory as OnStepXC6.ino)
// 2. Fill in your real values
// 3. Secrets.h is git-ignored and will never be committed
//
// Macros defined here override the placeholder defaults in
//   src/lib/wifi/WifiManager.defaults.h
// so you do NOT need to set them in Config.h.
// -------------------------------------------------------------------------------------------------

// ---- Access-Point mode (OnStep creates its own hotspot) -----
// SSID is set from HOST_NAME in Config.h; only the password needs a secret.
#define AP_PASSWORD        "changeme"

// ---- Station mode (OnStep joins your home network) ----------
#define STA_SSID           "YourNetworkName"
#define STA_PASSWORD       "YourNetworkPassword"

// ---- Second station (optional fallback network) -------------
// #define STA2_SSID        "FallbackNetwork"
// #define STA2_PASSWORD    "FallbackPassword"
